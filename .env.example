# AI Providers (at least one required — app falls back automatically)
# Gemini — get key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here

# DeepSeek — get key at https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=your_deepseek_key_here

# OpenAI — get key at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here

# Unsplash — get key at https://unsplash.com/developers
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
